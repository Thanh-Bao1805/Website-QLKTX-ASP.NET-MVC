@model DoAnCoSo.Models.DangKyDichVu

@{
    ViewData["Title"] = "Chi tiết đăng ký dịch vụ";
}

<div class="container px-4">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <dl class="row">
        <dt class="col-sm-3">Mã đăng ký</dt>
        <dd class="col-sm-9">@Model.MaDKDV</dd>

        <dt class="col-sm-3">Sinh viên</dt>
        <dd class="col-sm-9">@Model.SinhVien?.HoTen</dd>

        <dt class="col-sm-3">Dịch vụ</dt>
        <dd class="col-sm-9">@Model.DichVu?.TenDichVu</dd>

        <dt class="col-sm-3">Ngày đăng ký</dt>
        <dd class="col-sm-9">@Model.NgayDangKy.ToString("dd/MM/yyyy")</dd>

        <dt class="col-sm-3">Số lượng</dt>
        <dd class="col-sm-9">@Model.SoLuong</dd>

        <dt class="col-sm-3">Đơn giá</dt>
        <dd class="col-sm-9">@Model.DichVu?.DonGia.ToString("N0") VNĐ</dd>

        <dt class="col-sm-3">Tổng tiền</dt>
        <dd class="col-sm-9">@Model.TongTien.ToString("N0") VNĐ</dd>

        @if (Model.HoaDon != null)
        {
            <dt class="col-sm-3">Trạng thái thanh toán</dt>
            <dd class="col-sm-9">Đã thanh toán - Hóa đơn: @Model.HoaDon.MaHoaDon</dd>
        }
    </dl>
</div>

<div class="mt-3">
    <a asp-action="Update" asp-route-id="@Model.MaDKDV" class="btn btn-warning">Sửa</a>
    <a asp-action="Delete" asp-route-id="@Model.MaDKDV" class="btn btn-danger">Xóa</a>
    <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
</div> 