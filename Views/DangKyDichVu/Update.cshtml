@model DoAnCoSo.Models.DangKyDichVu

@{
    ViewData["Title"] = "Cập nhật đăng ký dịch vụ";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-edit me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Update" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
                
                <div class="row g-4">
                    <!-- Thông tin cơ bản -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Mã đăng ký</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="fas fa-hashtag"></i></span>
                                                <input class="form-control" value="@Model.MaDKDV" readonly />
                                                <input type="hidden" asp-for="MaDKDV" value="@Model.MaDKDV" />
                                            </div>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayDangKy" class="form-label">Ngày đăng ký</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="fas fa-calendar"></i></span>
                                                <input asp-for="NgayDangKy" class="form-control" type="date" />
                                            </div>
                                            <span asp-validation-for="NgayDangKy" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin sinh viên -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-user-graduate me-2"></i>Thông tin sinh viên
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaSV" class="form-label">Sinh viên</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="fas fa-user"></i></span>
                                                <select asp-for="MaSV" class="form-select" asp-items="ViewBag.SinhViens">
                                                    <option value="">-- Chọn sinh viên --</option>
                                                </select>
                                            </div>
                                            <span asp-validation-for="MaSV" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin dịch vụ -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-concierge-bell me-2"></i>Thông tin dịch vụ
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaDV" class="form-label">Dịch vụ</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="fas fa-concierge-bell"></i></span>
                                                <select asp-for="MaDV" class="form-select" asp-items="ViewBag.DichVus" id="maDV" onchange="updateDonGia()">
                                                    <option value="">-- Chọn dịch vụ --</option>
                                                </select>
                                            </div>
                                            <span asp-validation-for="MaDV" class="text-danger"></span>
                                            <input type="hidden" id="donGiaValue" value="@Model.DichVu?.DonGia" />
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="SoLuong" class="form-label">Số lượng</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="fas fa-sort-numeric-up"></i></span>
                                                <input asp-for="SoLuong" class="form-control" type="number" min="1" value="@Model.SoLuong" id="soLuong" onchange="updateTongTien()" />
                                            </div>
                                            <span asp-validation-for="SoLuong" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Tổng tiền</label>
                                            <div class="input-group">
                                                <span class="input-group-text"><i class="fas fa-money-bill"></i></span>
                                                <input type="text" class="form-control" id="tongTien" readonly value="@Model.TongTien.ToString("N0")" />
                                                <span class="input-group-text">VNĐ</span>
                                            </div>
                                            <input type="hidden" asp-for="TongTien" id="tongTienValue" value="@Model.TongTien" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-warning">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function updateDonGia() {
            const select = document.getElementById('maDV');
            const option = select.options[select.selectedIndex];
            const donGia = option.getAttribute('data-dongia');
            document.getElementById('donGiaValue').value = donGia;
            updateTongTien();
        }

        function updateTongTien() {
            const soLuong = parseInt(document.getElementById('soLuong').value) || 0;
            const donGia = parseFloat(document.getElementById('donGiaValue').value) || 0;
            const tongTien = soLuong * donGia;
            
            document.getElementById('tongTien').value = tongTien.toLocaleString('vi-VN');
            document.getElementById('tongTienValue').value = tongTien;
        }

        // Initialize total amount on page load
        document.addEventListener('DOMContentLoaded', function() {
            updateTongTien();
        });
    </script>
}
