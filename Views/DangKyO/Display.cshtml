---

@model DoAnCoSo.Models.DangKyO

@{
    ViewData["Title"] = "Chi tiết đăng ký ở";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-info text-white">
            <h2 class="mb-0">
                <i class="fas fa-info-circle"></i> @ViewData["Title"]
            </h2>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Thông tin sinh viên -->
                <div class="col-md-6">
                    <div class="card mb-3 h-100 border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-user text-primary"></i> Thông tin sinh viên
                            </h5>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Mã đăng ký</dt>
                                <dd class="col-sm-8">
                                    <span class="badge bg-primary">@Model.MaDK</span>
                                </dd>

                                <dt class="col-sm-4">MSSV</dt>
                                <dd class="col-sm-8">@Model.MSSV</dd>

                                <dt class="col-sm-4">Họ tên</dt>
                                <dd class="col-sm-8 fw-bold">@Model.HoTen</dd>

                                <dt class="col-sm-4">Ngày sinh</dt>
                                <dd class="col-sm-8">@Model.NgaySinh.ToString("dd/MM/yyyy")</dd>

                                <dt class="col-sm-4">Giới tính</dt>
                                <dd class="col-sm-8">
                                    @if (Model.GioiTinh == "Nam")
                                    {
                                        <i class="fas fa-mars text-primary me-1"></i>
                                    }
                                    else if (Model.GioiTinh == "Nữ")
                                    {
                                        <i class="fas fa-venus text-danger me-1"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-genderless text-secondary me-1"></i>
                                    }
                                    @Model.GioiTinh
                                </dd>

                                <dt class="col-sm-4">Số điện thoại</dt>
                                <dd class="col-sm-8">
                                    <a href="tel:@Model.SDT" class="text-decoration-none">
                                        <i class="fas fa-phone text-success me-1"></i>@Model.SDT
                                    </a>
                                </dd>

                                <dt class="col-sm-4">Email</dt>
                                <dd class="col-sm-8">
                                    <a href="mailto:@Model.Email" class="text-decoration-none">
                                        <i class="fas fa-envelope text-warning me-1"></i>@Model.Email
                                    </a>
                                </dd>

                                <dt class="col-sm-4">CCCD</dt>
                                <dd class="col-sm-8">
                                    <i class="fas fa-id-card text-info me-1"></i>@Model.CCCD
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>

                <!-- Thông tin học tập và phòng -->
                <div class="col-md-6">
                    <div class="card mb-3 border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-graduation-cap text-primary"></i> Thông tin học tập
                            </h5>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                <dt class="col-sm-4">Lớp</dt>
                                <dd class="col-sm-8">@Model.Lop</dd>

                                <dt class="col-sm-4">Khoa</dt>
                                <dd class="col-sm-8">@Model.Khoa</dd>

                                <dt class="col-sm-4">Địa chỉ</dt>
                                <dd class="col-sm-8">
                                    <i class="fas fa-map-marker-alt text-danger me-1"></i>@Model.DiaChiThuongTru
                                </dd>
                            </dl>
                        </div>
                    </div>

                    <div class="card border-0 shadow-sm">
                        <div class="card-header bg-light">
                            <h5 class="mb-0">
                                <i class="fas fa-home text-primary"></i> Thông tin đăng ký phòng
                            </h5>
                        </div>
                        <div class="card-body">
                            <dl class="row mb-0">
                                                                <dt class="col-sm-4">Mã phòng</dt>                                <dd class="col-sm-8">                                    @if (Model.MaPhong != null)                                    {                                        <span class="badge bg-info">@Model.MaPhong</span>                                    }                                    else                                    {                                        <span class="badge bg-secondary">Chưa có phòng</span>                                    }                                </dd>

                                <dt class="col-sm-4">Ngày bắt đầu</dt>
                                <dd class="col-sm-8">
                                    <i class="fas fa-calendar-alt text-primary me-1"></i>
                                    @Model.NgayBatDauO.ToString("dd/MM/yyyy")
                                </dd>

                                <dt class="col-sm-4">Ngày kết thúc</dt>
                                <dd class="col-sm-8">
                                    <i class="fas fa-calendar-check text-danger me-1"></i>
                                    @Model.NgayKetThucO.ToString("dd/MM/yyyy")
                                </dd>

                                <dt class="col-sm-4">Trạng thái</dt>
                                <dd class="col-sm-8">
                                    @{
                                        var today = DateTime.Today;
                                        if (today < Model.NgayBatDauO)
                                        {
                                            <span class="badge bg-info">
                                                <i class="fas fa-clock me-1"></i>Chưa bắt đầu
                                            </span>
                                        }
                                        else if (today > Model.NgayKetThucO)
                                        {
                                            <span class="badge bg-danger">
                                                <i class="fas fa-times-circle me-1"></i>Đã kết thúc
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-success">
                                                <i class="fas fa-check-circle me-1"></i>Đang ở
                                            </span>
                                        }
                                    }
                                </dd>
                            </dl>
                        </div>
                    </div>
                </div>
            </div>

            <div class="text-center mt-4">
                @if (User.IsInRole("Admin"))
                {
                    <a asp-action="Update" asp-route-id="@Model.MaDK" class="btn btn-warning btn-lg px-4">
                        <i class="fas fa-edit me-2"></i>Chỉnh sửa
                    </a>
                    <a asp-action="Delete" asp-route-id="@Model.MaDK" class="btn btn-danger btn-lg px-4 mx-2">
                        <i class="fas fa-trash me-2"></i>Xóa
                    </a>
                }
                <a asp-action="Index" class="btn btn-secondary btn-lg px-4">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
    </div>
</div>

<style>
    dt {
        font-weight: 600;
        color: #495057;
    }

    dd {
        color: #343a40;
        margin-bottom: 0.75rem;
    }

    .card {
        border-radius: 0.5rem;
        overflow: hidden;
    }

    .card-header {
        border-bottom: none;
        padding: 1rem;
    }

    .card-body {
        padding: 1.25rem;
    }

    .badge {
        font-weight: 500;
        padding: 0.5em 0.75em;
    }

    .btn-lg {
        border-radius: 0.5rem;
    }

    .card-header h5 {
        font-size: 1.1rem;
        font-weight: 600;
    }

    a {
        color: inherit;
    }

    a:hover {
        color: var(--bs-primary);
    }
</style>
