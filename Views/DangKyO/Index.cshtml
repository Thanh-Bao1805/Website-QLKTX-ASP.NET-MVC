@model IEnumerable<DoAnCoSo.Models.DangKyO>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Danh sách Đăng ký ở";
    var currentUser = await UserManager.GetUserAsync(User);
    var isAdmin = await UserManager.IsInRoleAsync(currentUser, "Admin");
    var isNhanVien = await UserManager.IsInRoleAsync(currentUser, "NhanVien");
    var isStaff = isAdmin || isNhanVien;
}

<div class="container-fluid mt-4">
    <div class="card shadow">
        <div class="card-header bg-gradient-primary text-white d-flex justify-content-between align-items-center" style="background: linear-gradient(to right, #007bff, #0056b3);">
            <h2 class="mb-0">
                <i class="fas fa-list me-2"></i>@ViewData["Title"]
                @if (!isStaff)
                {
                    <small class="fs-6">(Chỉ hiển thị phiếu của bạn)</small>
                }
            </h2>
            @if (isStaff)
            {
                <a asp-action="Add" class="btn btn-light btn-sm">
                    <i class="fas fa-plus me-1"></i> Thêm mới
                </a>
            }
            else
            {
                <a asp-action="Add" class="btn btn-light btn-sm">
                    <i class="fas fa-plus me-1"></i> Đăng ký mới
                </a>
            }
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="text-center p-4">
                    <i class="fas fa-clipboard-list fa-3x text-muted mb-3"></i>
                    <h4 class="text-muted">Chưa có phiếu đăng ký nào</h4>
                    @if (!isStaff)
                    {
                        <p class="text-muted">Bạn chưa có phiếu đăng ký nào. Hãy tạo phiếu mới!</p>
                    }
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-bordered table-striped table-hover align-middle mb-0">
                        <thead class="table-light text-center align-middle">
                            <tr>
                                <th>Mã ĐK</th>
                                <th>MSSV</th>
                                <th>Họ Tên</th>
                                <th>Ngày Sinh</th>
                                <th>Giới Tính</th>
                                <th>SDT</th>
                                <th>Email</th>
                                @if (isStaff)
                                {
                                    <th>CCCD</th>
                                }
                                <th>Lớp</th>
                                <th>Khoa</th>
                                @if (isStaff)
                                {
                                    <th>Địa chỉ</th>
                                }
                                <th>Từ ngày</th>
                                <th>Đến ngày</th>
                                <th>Phòng</th>
                                <th>Trạng thái</th>
                                <th>Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><span class="badge bg-primary">@item.MaDK</span></td>
                                    <td>@item.MSSV</td>
                                    <td class="fw-semibold">@item.HoTen</td>
                                    <td>@item.NgaySinh.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        @if (item.GioiTinh == "Nam")
                                        {
                                            <i class="fas fa-mars text-primary"></i>
                                        }
                                        else if (item.GioiTinh == "Nữ")
                                        {
                                            <i class="fas fa-venus text-danger"></i>
                                        }
                                        else
                                        {
                                            <i class="fas fa-genderless text-secondary"></i>
                                        }
                                        <span class="ms-1">@item.GioiTinh</span>
                                    </td>
                                    <td>
                                        <a href="tel:@item.SDT" class="text-decoration-none text-success">
                                            <i class="fas fa-phone me-1"></i>@item.SDT
                                        </a>
                                    </td>
                                    <td>
                                        <a href="mailto:@item.Email" class="text-decoration-none text-warning">
                                            <i class="fas fa-envelope me-1"></i>@item.Email
                                        </a>
                                    </td>
                                    @if (isStaff)
                                    {
                                        <td><i class="fas fa-id-card me-1 text-info"></i>@item.CCCD</td>
                                    }
                                    <td>@item.Lop</td>
                                    <td>@item.Khoa</td>
                                    @if (isStaff)
                                    {
                                        <td><i class="fas fa-map-marker-alt me-1 text-danger"></i>@item.DiaChiThuongTru</td>
                                    }
                                    <td>@item.NgayBatDauO.ToString("dd/MM/yyyy")</td>
                                    <td>@item.NgayKetThucO.ToString("dd/MM/yyyy")</td>
                                    <td class="text-center">
                                        @if (item.Phong != null)
                                        {
                                            <span class="badge bg-info">@item.Phong.MaPhong</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Chưa có</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @{
                                            var today = DateTime.Today;
                                            if (today < item.NgayBatDauO)
                                            {
                                                <span class="badge bg-info">
                                                    <i class="fas fa-clock me-1"></i>Chưa bắt đầu
                                                </span>
                                            }
                                            else if (today > item.NgayKetThucO)
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="fas fa-times-circle me-1"></i>Đã kết thúc
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success">
                                                    <i class="fas fa-check-circle me-1"></i>Đang ở
                                                </span>
                                            }
                                        }
                                    </td>
                                    <td class="text-center">
                                        <div class="btn-group btn-group-sm">
                                            <a asp-action="Display" asp-route-id="@item.MaDK" class="btn btn-outline-info" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            @if (isAdmin || (isNhanVien && item.UserId == currentUser?.Id))
                                            {
                                                <a asp-action="Update" asp-route-id="@item.MaDK" class="btn btn-outline-warning" title="Chỉnh sửa">
                                                    <i class="fas fa-edit"></i>
                                                </a>
                                            }
                                            @if (isAdmin)
                                            {
                                                <a asp-action="Delete" asp-route-id="@item.MaDK" class="btn btn-outline-danger" title="Xóa">
                                                    <i class="fas fa-trash"></i>
                                                </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>