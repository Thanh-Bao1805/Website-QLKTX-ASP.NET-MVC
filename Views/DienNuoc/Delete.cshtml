@model DoAnCoSo.Models.DienNuoc
@{
    ViewData["Title"] = "Xóa Dữ Liệu Điện Nước";
}

<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>@ViewData["Title"]
                        </h5>
                        <a asp-action="Index" class="btn btn-light btn-sm">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </div>

                <div class="card-body text-center py-4">
                    <div class="mb-4">
                        <i class="fas fa-trash-alt fa-4x text-danger mb-3"></i>
                        <h4 class="text-danger">Bạn có chắc chắn muốn xóa?</h4>
                        <p class="text-muted">Thao tác này không thể hoàn tác. Dữ liệu điện nước sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
                    </div>

                    <!-- Thông tin điện nước -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <strong>Mã điện nước:</strong>
                                    <br>
                                    <span class="badge bg-secondary fs-6">@Model.MaDN</span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong>Ngày ghi:</strong>
                                    <br>
                                    @Model.NgayGhi.ToString("dd/MM/yyyy")
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong>Phòng:</strong>
                                    <br>
                                    <span class="badge bg-primary">@Model.Phong?.MaPhong</span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong>Tổng tiền:</strong>
                                    <br>
                                    <span class="fw-bold text-success fs-6">@Model.TongTien.ToString("N0") VNĐ</span>
                                </div>
                                <div class="col-12">
                                    <hr>
                                    <strong>Chi tiết sử dụng:</strong>
                                    <div class="row mt-2">
                                        <div class="col-md-6">
                                            <small class="text-muted">Số điện:</small>
                                            <br>
                                            <span class="fw-bold">@Model.SoDien kWh</span>
                                        </div>
                                        <div class="col-md-6">
                                            <small class="text-muted">Đơn giá điện:</small>
                                            <br>
                                            <span class="fw-bold">@Model.DonGiaDien.ToString("N0") VNĐ</span>
                                        </div>
                                        <div class="col-md-6">
                                            <small class="text-muted">Số nước:</small>
                                            <br>
                                            <span class="fw-bold">@Model.SoNuoc m³</span>
                                        </div>
                                        <div class="col-md-6">
                                            <small class="text-muted">Đơn giá nước:</small>
                                            <br>
                                            <span class="fw-bold">@Model.DonGiaNuoc.ToString("N0") VNĐ</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form xóa -->
                    <form asp-action="DeleteConfirmed" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.MaDN" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-secondary px-4">
                                <i class="fas fa-times me-2"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash me-2"></i>Xác nhận xóa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .badge {
            font-size: 0.8em;
            padding: 0.5em 0.75em;
        }

        .fs-6 {
            font-size: 1.1rem !important;
        }
    </style>
}