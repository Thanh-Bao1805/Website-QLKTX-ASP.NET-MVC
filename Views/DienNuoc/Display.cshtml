@model DoAnCoSo.Models.DienNuoc
@{
    ViewData["Title"] = "Chi tiết Điện Nước";
}

<div class="container-fluid px-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>@ViewData["Title"]
                        </h5>
                        <div>
                            <a asp-action="Index" class="btn btn-light btn-sm me-2">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại
                            </a>
                             @if (User.IsInRole("Admin"))
                                {
                            <a asp-action="Update" asp-route-id="@Model.MaDN" class="btn btn-warning btn-sm me-2">
                                <i class="fas fa-edit me-2"></i>Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.MaDN" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash me-2"></i>Xóa
                            </a>
                            }
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <div class="row">
                        <!-- Thông tin cơ bản -->
                        <div class="col-md-6">
                            <div class="card mb-4">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-info-circle me-2 text-primary"></i>Thông tin cơ bản
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Mã điện nước:</div>
                                        <div class="col-sm-8">
                                            <span class="badge bg-secondary fs-6">@Model.MaDN</span>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Ngày ghi:</div>
                                        <div class="col-sm-8">@Model.NgayGhi.ToString("dd/MM/yyyy")</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Phòng:</div>
                                        <div class="col-sm-8">
                                            <span class="badge bg-primary">@Model.Phong?.MaPhong</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Tổng tiền -->
                        <div class="col-md-6">
                            <div class="card mb-4 bg-success text-white">
                                <div class="card-body text-center">
                                    <h6 class="card-title mb-3">
                                        <i class="fas fa-money-bill-wave me-2"></i>Tổng tiền
                                    </h6>
                                    <h2 class="fw-bold">@Model.TongTien.ToString("N0") VNĐ</h2>
                                    <small>Tổng chi phí điện nước</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Chi tiết điện nước -->
                    <div class="row">
                        <!-- Thông tin điện -->
                        <div class="col-md-6">
                            <div class="card mb-4">
                                <div class="card-header bg-info text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-bolt me-2"></i>Thông tin điện
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-sm-6 fw-bold">Số điện:</div>
                                        <div class="col-sm-6">@Model.SoDien kWh</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-6 fw-bold">Đơn giá điện:</div>
                                        <div class="col-sm-6">@Model.DonGiaDien.ToString("N0") VNĐ/kWh</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-6 fw-bold">Thành tiền:</div>
                                        <div class="col-sm-6 fw-bold text-success">
                                            @((Model.SoDien * Model.DonGiaDien).ToString("N0")) VNĐ
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Thông tin nước -->
                        <div class="col-md-6">
                            <div class="card mb-4">
                                <div class="card-header bg-primary text-white">
                                    <h6 class="mb-0">
                                        <i class="fas fa-tint me-2"></i>Thông tin nước
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-sm-6 fw-bold">Số nước:</div>
                                        <div class="col-sm-6">@Model.SoNuoc m³</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-6 fw-bold">Đơn giá nước:</div>
                                        <div class="col-sm-6">@Model.DonGiaNuoc.ToString("N0") VNĐ/m³</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-6 fw-bold">Thành tiền:</div>
                                        <div class="col-sm-6 fw-bold text-success">
                                            @((Model.SoNuoc * Model.DonGiaNuoc).ToString("N0")) VNĐ
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Phân tích chi phí -->
                    <div class="card">
                        <div class="card-header bg-warning text-dark">
                            <h6 class="mb-0">
                                <i class="fas fa-chart-pie me-2"></i>Phân tích chi phí
                            </h6>
                        </div>
                        <div class="card-body">
                            @{
                                var tienDien = Model.SoDien * Model.DonGiaDien;
                                var tienNuoc = Model.SoNuoc * Model.DonGiaNuoc;
                                var tongTien = Model.TongTien;
                                var phanTramDien = tongTien > 0 ? (tienDien / tongTien * 100) : 0;
                                var phanTramNuoc = tongTien > 0 ? (tienNuoc / tongTien * 100) : 0;
                            }
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span>Điện (@phanTramDien.ToString("F1")%)</span>
                                            <span class="fw-bold">@tienDien.ToString("N0") VNĐ</span>
                                        </div>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-info" role="progressbar"
                                                 style="width: @phanTramDien%"
                                                 aria-valuenow="@phanTramDien" aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="mb-3">
                                        <div class="d-flex justify-content-between mb-1">
                                            <span>Nước (@phanTramNuoc.ToString("F1")%)</span>
                                            <span class="fw-bold">@tienNuoc.ToString("N0") VNĐ</span>
                                        </div>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-primary" role="progressbar"
                                                 style="width: @phanTramNuoc%"
                                                 aria-valuenow="@phanTramNuoc" aria-valuemin="0" aria-valuemax="100">
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .badge {
            font-size: 0.8em;
            padding: 0.5em 0.75em;
        }

        .fs-6 {
            font-size: 1.1rem !important;
        }

        .progress {
            border-radius: 10px;
        }

        .progress-bar {
            border-radius: 10px;
        }
    </style>
}