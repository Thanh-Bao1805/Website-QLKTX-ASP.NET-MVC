@model IEnumerable<DoAnCoSo.Models.DienNuoc>
@{
    ViewData["Title"] = "Quản Lý Điện Nước";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-bolt me-2"></i>@ViewData["Title"]
                </h5>
                 @if (User.IsInRole("Admin"))
                                {
                <a asp-action="Add" class="btn btn-light">
                    <i class="fas fa-plus me-2"></i>Thêm mới
                </a>
                }
            </div>
        </div>

        <div class="card-body p-0">
            <!-- Hiển thị thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-bolt fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Chưa có dữ liệu điện nước</h5>
                    <p class="text-muted">Hãy thêm dữ liệu mới để bắt đầu quản lý</p>
                    <a asp-action="Add" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Thêm dữ liệu đầu tiên
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã</th>
                                <th>Ngày ghi</th>
                                <th>Phòng</th>
                                <th>Số điện</th>
                                <th>Số nước</th>
                                <th>Tổng tiền</th>
                                <th width="150">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">@item.MaDN</span>
                                    </td>
                                    <td>@item.NgayGhi.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        <span class="badge bg-primary">@item.Phong?.MaPhong</span>
                                    </td>
                                    <td>@item.SoDien kWh</td>
                                    <td>@item.SoNuoc m³</td>
                                    <td>
                                        <span class="fw-bold text-success">@item.TongTien.ToString("N0") VNĐ</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Display" asp-route-id="@item.MaDN" class="btn btn-outline-primary" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                             @if (User.IsInRole("Admin"))
                                {
                                            <a asp-action="Update" asp-route-id="@item.MaDN" class="btn btn-outline-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaDN" class="btn btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Thống kê -->
        @if (Model.Any())
        {
            <div class="card-footer bg-light">
                <div class="row text-center">
                    <div class="col-md-4">
                        <span class="fw-bold text-primary">@Model.Count()</span>
                        <small class="text-muted">Tổng số bản ghi</small>
                    </div>
                    <div class="col-md-4">
                        <span class="fw-bold text-success">@Model.Sum(d => d.TongTien).ToString("N0") VNĐ</span>
                        <small class="text-muted">Tổng doanh thu</small>
                    </div>
                    <div class="col-md-4">
                        <span class="fw-bold text-info">@Model.Average(d => d.TongTien).ToString("N0") VNĐ</span>
                        <small class="text-muted">Trung bình/bản ghi</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .table th {
            border-top: none;
            font-weight: 600;
            color: #495057;
        }

        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .btn-group .btn {
            border-radius: 5px;
            margin: 0 2px;
        }

        .badge {
            font-size: 0.75em;
        }
    </style>
}