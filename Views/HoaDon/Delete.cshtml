@model DoAnCoSo.Models.HoaDon
@{
    ViewData["Title"] = "Xóa hóa đơn";
    string loaiHoaDon = Model.LoaiChiPhi == "HoaDonDienNuoc" ? "Hóa đơn điện nước" : 
                        Model.LoaiChiPhi == "HoaDonDichVu" ? "Hóa đơn dịch vụ" : Model.LoaiChiPhi;
}

<div class="container-fluid px-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">@ViewData["Title"]</h5>
            </div>
        </div>
        <div class="card-body">
            <div class="alert alert-danger">
                <h6 class="alert-heading">
                    <i class="fas fa-exclamation-triangle me-2"></i>Xác nhận xóa
                </h6>
                <p class="mb-0">Bạn có chắc chắn muốn xóa hóa đơn có mã "@Model.MaHoaDon" không?</p>
            </div>

            <div class="row g-4">
                <!-- Thông tin cơ bản -->
                <div class="col-12">
                    <div class="card bg-light">
                        <div class="card-body">
                            <h6 class="card-title mb-3">
                                <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="detail-group">
                                        <label class="text-muted mb-1">Mã hóa đơn</label>
                                        <p class="h5">@Model.MaHoaDon</p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-group">
                                        <label class="text-muted mb-1">Ngày lập</label>
                                        <p class="h5">@Model.NgayLap.ToString("dd/MM/yyyy")</p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-group">
                                        <label class="text-muted mb-1">Loại hóa đơn</label>
                                        <p class="h5">
                                            @if (Model.LoaiChiPhi == "HoaDonDienNuoc")
                                            {
                                                <span class="badge bg-info">@loaiHoaDon</span>
                                            }
                                            else if (Model.LoaiChiPhi == "HoaDonDichVu")
                                            {
                                                <span class="badge bg-success">@loaiHoaDon</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="detail-group">
                                        <label class="text-muted mb-1">Sinh viên</label>
                                        <p class="h5">@Model.SinhVien?.HoTen</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Thông tin thanh toán -->
                <div class="col-12">
                    <div class="card bg-light">
                        <div class="card-body">
                            <h6 class="card-title mb-3">
                                <i class="fas fa-money-bill me-2"></i>Thông tin thanh toán
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-4">
                                
                                </div>
                                <div class="col-md-4">
                                    <div class="detail-group">
                                        <label class="text-muted mb-1">Tổng tiền</label>
                                        <p class="h5 text-danger">@Model.TongTien.ToString("N0") VNĐ</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Thông tin tham chiếu -->
                <div class="col-12">
                    <div class="card bg-light">
                        <div class="card-body">
                            <h6 class="card-title mb-3">
                                <i class="fas fa-link me-2"></i>Thông tin tham chiếu
                            </h6>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <div class="detail-group">
                                        <label class="text-muted mb-1">Mã tham chiếu</label>
                                        <p class="h5">
                                            @if (Model.LoaiChiPhi == "HoaDonDienNuoc")
                                            {
                                                <span class="badge bg-light text-dark">@Model.MaDN</span>
                                            }
                                            else if (Model.LoaiChiPhi == "HoaDonDichVu")
                                            {
                                                <span class="badge bg-light text-dark">@Model.MaDKDV</span>
                                            }
                                        </p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="MaHoaDon" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Xác nhận xóa
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="fas fa-times me-2"></i>Hủy
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .detail-group label {
            font-size: 0.875rem;
        }
        .detail-group p {
            margin-bottom: 0;
        }
        .badge {
            font-weight: 500;
            padding: 0.5em 0.8em;
            border-radius: 6px;
        }
        .card-title {
            font-weight: 600;
        }
        .alert-heading {
            font-weight: 600;
        }
    </style>
}
