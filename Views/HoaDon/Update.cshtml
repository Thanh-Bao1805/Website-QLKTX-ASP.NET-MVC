@model DoAnCoSo.Models.HoaDon
@{
    ViewData["Title"] = "Cập nhật hóa đơn";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-edit me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <form asp-action="Update" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>
                <input type="hidden" asp-for="MaHoaDon" />
                
                <div class="row g-4">
                    <!-- Thông tin cơ bản -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaHoaDon" class="form-label">Mã hóa đơn</label>
                                            <input asp-for="MaHoaDon" class="form-control" readonly />
                                            <span asp-validation-for="MaHoaDon" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayLap" class="form-label">Ngày lập</label>
                                            <input asp-for="NgayLap" class="form-control" type="date" required />
                                            <span asp-validation-for="NgayLap" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin liên quan -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-link me-2"></i>Thông tin liên quan
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="LoaiChiPhi" class="form-label">Loại chi phí</label>
                                            <select asp-for="LoaiChiPhi" class="form-select" required>
                                                <option value="HoaDonDienNuoc">Hóa đơn điện nước</option>
                                                <option value="HoaDonDichVu">Hóa đơn dịch vụ</option>
                                            </select>
                                            <span asp-validation-for="LoaiChiPhi" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaSV" class="form-label">Sinh viên</label>
                                            <select asp-for="MaSV" class="form-select">
                                                <option value="">-- Chọn sinh viên --</option>
                                                @if (ViewBag.SinhVienList != null)
                                                {
                                                    foreach (var sv in ViewBag.SinhVienList)
                                                    {
                                                        <option value="@sv.MaSV">@sv.HoTen</option>
                                                    }
                                                }
                                            </select>
                                            <span asp-validation-for="MaSV" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaNV" class="form-label">Nhân viên</label>
                                            <select asp-for="MaNV" class="form-select">
                                                <option value="">-- Chọn nhân viên --</option>
                                                @if (ViewBag.NhanVienList != null)
                                                {
                                                    foreach (var nv in ViewBag.NhanVienList)
                                                    {
                                                        <option value="@nv.MaNV">@nv.HoTen</option>
                                                    }
                                                }
                                            </select>
                                            <span asp-validation-for="MaNV" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6 dien-nuoc-field" style="display: none;">
                                        <div class="form-group">
                                            <label asp-for="MaDN" class="form-label">Mã điện nước</label>
                                            <select asp-for="MaDN" class="form-select">
                                                <option value="">-- Chọn mã điện nước --</option>
                                                @if (ViewBag.DienNuocList != null)
                                                {
                                                    foreach (var dn in ViewBag.DienNuocList)
                                                    {
                                                        <option value="@dn.MaDN">@dn.MaDN</option>
                                                    }
                                                }
                                            </select>
                                            <span asp-validation-for="MaDN" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6 dich-vu-field" style="display: none;">
                                        <div class="form-group">
                                            <label asp-for="MaDKDV" class="form-label">Mã đăng ký dịch vụ</label>
                                            <select asp-for="MaDKDV" class="form-select">
                                                <option value="">-- Chọn mã đăng ký dịch vụ --</option>
                                                @if (ViewBag.DangKyDichVuList != null)
                                                {
                                                    foreach (var dkdv in ViewBag.DangKyDichVuList)
                                                    {
                                                        <option value="@dkdv.MaDKDV">@dkdv.MaDKDV</option>
                                                    }
                                                }
                                            </select>
                                            <span asp-validation-for="MaDKDV" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin thanh toán -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-money-bill me-2"></i>Thông tin thanh toán
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="TrangThai" class="form-label">Trạng thái thanh toán</label>
                                            <select asp-for="TrangThai" class="form-select" required>
                                                <option value="Chờ thanh toán">Chờ thanh toán</option>
                                                <option value="Đã thanh toán">Đã thanh toán</option>
                                            </select>
                                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Tổng tiền</label>
                                            <p class="form-control-plaintext">@Model.TongTien.ToString("N2") VNĐ</p>
                                            <input type="hidden" asp-for="TongTien" value="@Model.TongTien.ToString(System.Globalization.CultureInfo.InvariantCulture)" />
                                            <span asp-validation-for="TongTien" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Nút lưu -->
                    <div class="col-12 text-end">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-2"></i>Lưu thay đổi
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        $(document).ready(function() {
            // Hiển thị/ẩn các trường dựa trên loại chi phí
            function toggleFields() {
                var loaiChiPhi = $('#LoaiChiPhi').val();
                if (loaiChiPhi === 'HoaDonDienNuoc') {
                    $('.dien-nuoc-field').show();
                    $('.dich-vu-field').hide();
                } else if (loaiChiPhi === 'HoaDonDichVu') {
                    $('.dien-nuoc-field').hide();
                    $('.dich-vu-field').show();
                } else {
                    $('.dien-nuoc-field').hide();
                    $('.dich-vu-field').hide();
                }
            }

            // Gọi hàm khi trang được tải
            toggleFields();

            // Gọi hàm khi loại chi phí thay đổi
            $('#LoaiChiPhi').change(function() {
                toggleFields();
            });
        });
    </script>
}
