@model DoAnCoSo.Models.HopDong
@{
    ViewData["Title"] = "Thêm Hợp Đồng";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-file-contract me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-light">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Hiển thị thông báo -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Add" method="post" id="hopDongForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <!-- THÊM HIDDEN FIELD CHO MaHopDong -->
                <input type="hidden" asp-for="MaHopDong" id="hiddenMaHopDong" />

                <div class="row g-4">
                    <!-- Thông tin hợp đồng -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-primary">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin hợp đồng
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label fw-bold">Mã hợp đồng (tự động)</label>
                                            <input type="text" class="form-control bg-light" id="autoGeneratedCode"
                                                   value="Hệ thống sẽ tự sinh mã" readonly />
                                            <small class="form-text text-muted">Mã sẽ được tự động sinh: HD001, HD002, ...</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái *</label>
                                            <select asp-for="TrangThai" class="form-select" required>
                                                <option value="">-- Chọn trạng thái --</option>
                                                <option value="Đang hoạt động">Đang hoạt động</option>
                                                <option value="Tạm ngưng">Tạm ngưng</option>
                                                <option value="Đã kết thúc">Đã kết thúc</option>
                                                <option value="Hủy bỏ">Hủy bỏ</option>
                                            </select>
                                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thời gian hợp đồng -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-success">
                                    <i class="fas fa-calendar-alt me-2"></i>Thời gian hợp đồng
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayBatDau" class="form-label fw-bold">Ngày bắt đầu *</label>
                                            <input asp-for="NgayBatDau" type="date" class="form-control" required
                                                   onchange="validateDates()" />
                                            <span asp-validation-for="NgayBatDau" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayKetThuc" class="form-label fw-bold">Ngày kết thúc *</label>
                                            <input asp-for="NgayKetThuc" type="date" class="form-control" required
                                                   onchange="validateDates()" />
                                            <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
                                            <div id="dateError" class="text-danger small mt-1" style="display: none;">
                                                Ngày kết thúc phải sau ngày bắt đầu
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin liên quan -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-info">
                                    <i class="fas fa-users me-2"></i>Thông tin liên quan
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label asp-for="MaSV" class="form-label fw-bold">Sinh viên *</label>
                                            <select asp-for="MaSV" class="form-select" required>
                                                <option value="">-- Chọn sinh viên --</option>
                                                @foreach (var sv in ViewBag.SinhViens)
                                                {
                                                    <option value="@sv.Value">@sv.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaSV" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label asp-for="MaPhong" class="form-label fw-bold">Phòng *</label>
                                            <select asp-for="MaPhong" class="form-select" required>
                                                <option value="">-- Chọn phòng --</option>
                                                @foreach (var phong in ViewBag.Phongs)
                                                {
                                                    <option value="@phong.Value">@phong.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaPhong" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="form-group">
                                            <label asp-for="MaNV" class="form-label fw-bold">Nhân viên *</label>
                                            <select asp-for="MaNV" class="form-select" required>
                                                <option value="">-- Chọn nhân viên --</option>
                                                @foreach (var nv in ViewBag.NhanViens)
                                                {
                                                    <option value="@nv.Value">@nv.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaNV" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success px-4" onclick="return validateForm()">
                        <i class="fas fa-save me-2"></i>Lưu hợp đồng
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Tự động sinh mã khi trang load
            generateMaHopDong();
        });

        // Hàm sinh mã hợp đồng
        function generateMaHopDong() {
            $.get('@Url.Action("GenerateMaHopDong", "HopDong")')
                .done(function (data) {
                    if (data.success) {
                        $('#autoGeneratedCode').val(data.maHopDong);
                        $('#hiddenMaHopDong').val(data.maHopDong);
                    } else {
                        $('#autoGeneratedCode').val('Lỗi khi sinh mã');
                    }
                })
                .fail(function () {
                    $('#autoGeneratedCode').val('Lỗi kết nối');
                });
        }

        // Hàm validate ngày
        function validateDates() {
            var ngayBatDau = new Date($('#NgayBatDau').val());
            var ngayKetThuc = new Date($('#NgayKetThuc').val());
            var dateError = $('#dateError');

            if (ngayBatDau && ngayKetThuc && ngayKetThuc <= ngayBatDau) {
                dateError.show();
                return false;
            } else {
                dateError.hide();
                return true;
            }
        }

        // Hàm validate form
        function validateForm() {
            var maHopDong = $('#hiddenMaHopDong').val();

            if (!maHopDong || maHopDong === '') {
                alert('Mã hợp đồng chưa được sinh. Vui lòng thử lại.');
                return false;
            }

            if (!validateDates()) {
                alert('Ngày kết thúc phải sau ngày bắt đầu');
                return false;
            }

            return true;
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .form-label {
            font-weight: 500;
        }

        .card-title {
            font-weight: 600;
        }

        #autoGeneratedCode {
            font-weight: bold;
            color: #0d6efd;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }
    </style>
}