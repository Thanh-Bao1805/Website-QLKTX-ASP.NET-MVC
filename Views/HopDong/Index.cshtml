@model IEnumerable<DoAnCoSo.Models.HopDong>
@{
    ViewData["Title"] = "Quản Lý Hợp Đồng";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-file-contract me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Add" class="btn btn-light">
                    <i class="fas fa-plus me-2"></i>Thêm hợp đồng
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <!-- Hiển thị thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-file-contract fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Chưa có hợp đồng nào</h5>
                    <p class="text-muted">Hãy thêm hợp đồng mới để bắt đầu quản lý</p>
                    <a asp-action="Add" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Thêm hợp đồng đầu tiên
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã HĐ</th>
                                <th>Sinh viên</th>
                                <th>Phòng</th>
                                <th>Ngày bắt đầu</th>
                                <th>Ngày kết thúc</th>
                                <th>Trạng thái</th>
                                <th width="150">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">@item.MaHopDong</span>
                                    </td>
                                    <td>
                                        <div class="fw-bold">@item.SinhVien?.HoTen</div>
                                        <small class="text-muted">@item.MaSV</small>
                                    </td>
                                    <td>
                                        <span class="badge bg-primary">@item.Phong?.MaPhong</span>
                                    </td>
                                    <td>@item.NgayBatDau.ToString("dd/MM/yyyy")</td>
                                    <td>@item.NgayKetThuc.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @{
                                            var badgeClass = item.TrangThai switch
                                            {
                                                "Đang hoạt động" => "bg-success",
                                                "Đã kết thúc" => "bg-secondary",
                                                "Tạm ngưng" => "bg-warning",
                                                "Hủy bỏ" => "bg-danger",
                                                _ => "bg-info"
                                            };
                                        }
                                        <span class="badge @badgeClass">@item.TrangThai</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Display" asp-route-id="@item.MaHopDong" class="btn btn-outline-primary" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Update" asp-route-id="@item.MaHopDong" class="btn btn-outline-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaHopDong" class="btn btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Thống kê -->
        @if (Model.Any())
        {
            <div class="card-footer bg-light">
                <div class="row text-center">
                    <div class="col-md-3">
                        <span class="fw-bold text-primary">@Model.Count()</span>
                        <small class="text-muted">Tổng số</small>
                    </div>
                    <div class="col-md-3">
                        <span class="fw-bold text-success">@Model.Count(h => h.TrangThai == "Đang hoạt động")</span>
                        <small class="text-muted">Đang hoạt động</small>
                    </div>
                    <div class="col-md-3">
                        <span class="fw-bold text-warning">@Model.Count(h => h.TrangThai == "Tạm ngưng")</span>
                        <small class="text-muted">Tạm ngưng</small>
                    </div>
                    <div class="col-md-3">
                        <span class="fw-bold text-secondary">@Model.Count(h => h.TrangThai == "Đã kết thúc")</span>
                        <small class="text-muted">Đã kết thúc</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .table th {
            border-top: none;
            font-weight: 600;
            color: #495057;
        }

        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .btn-group .btn {
            border-radius: 5px;
            margin: 0 2px;
        }

        .badge {
            font-size: 0.75em;
        }
    </style>
}