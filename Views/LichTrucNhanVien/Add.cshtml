@model DoAnCoSo.Models.LichTrucNhanVien
@{
    ViewData["Title"] = "Thêm Lịch Trực";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-calendar-plus me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-light">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Hiển thị thông báo -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Add" method="post" id="lichTrucForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <!-- THÊM HIDDEN FIELD CHO MaLT -->
                <input type="hidden" asp-for="MaLT" id="hiddenMaLT" />

                <div class="row g-4">
                    <!-- Thông tin lịch trực -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-primary">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin lịch trực
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label fw-bold">Mã lịch trực (tự động)</label>
                                            <input type="text" class="form-control bg-light" id="autoGeneratedCode"
                                                   value="Đang sinh mã..." readonly />
                                            <small class="form-text text-muted">Mã sẽ được tự động sinh: LT001, LT002, ...</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayTruc" class="form-label fw-bold">Ngày trực *</label>
                                            <input asp-for="NgayTruc" type="date" class="form-control" required />
                                            <span asp-validation-for="NgayTruc" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="CaTruc" class="form-label fw-bold">Ca trực *</label>
                                            <select asp-for="CaTruc" class="form-select" required>
                                                <option value="">-- Chọn ca trực --</option>
                                                <option value="Sáng">Ca sáng (7h - 12h)</option>
                                                <option value="Chiều">Ca chiều (13h - 18h)</option>
                                                <option value="Tối">Ca tối (19h - 22h)</option>
                                            </select>
                                            <span asp-validation-for="CaTruc" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaNV" class="form-label fw-bold">Nhân viên *</label>
                                            <select asp-for="MaNV" class="form-select" required>
                                                <option value="">-- Chọn nhân viên --</option>
                                                @foreach (var nv in ViewBag.NhanViens)
                                                {
                                                    <option value="@nv.Value">@nv.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaNV" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success px-4" id="submitButton">
                        <i class="fas fa-save me-2"></i>Lưu lịch trực
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Tự động sinh mã khi trang load
            generateMaLT();

            // Xử lý sự kiện submit form
            $('#lichTrucForm').on('submit', function (e) {
                return validateForm(e);
            });
        });

        // Hàm sinh mã lịch trực
        function generateMaLT() {
            $('#autoGeneratedCode').val('Đang sinh mã...');
            $('#submitButton').prop('disabled', true);

            $.get('@Url.Action("GenerateMaLT", "LichTrucNhanVien")')
                .done(function (data) {
                    if (data.success) {
                        $('#autoGeneratedCode').val(data.maLT);
                        $('#hiddenMaLT').val(data.maLT);
                        $('#submitButton').prop('disabled', false);
                    } else {
                        $('#autoGeneratedCode').val('Lỗi khi sinh mã');
                        $('#submitButton').prop('disabled', true);
                        alert('Lỗi khi sinh mã: ' + data.message);
                    }
                })
                .fail(function (xhr, status, error) {
                    $('#autoGeneratedCode').val('Lỗi kết nối');
                    $('#submitButton').prop('disabled', true);
                    alert('Lỗi kết nối đến server: ' + error);
                });
        }

        // Hàm validate form
        function validateForm(e) {
            var maLT = $('#hiddenMaLT').val();
            var ngayTruc = $('#NgayTruc').val();
            var caTruc = $('#CaTruc').val();
            var maNV = $('#MaNV').val();

            // Kiểm tra mã lịch trực
            if (!maLT || maLT === '') {
                alert('Mã lịch trực chưa được sinh. Vui lòng đợi hoặc tải lại trang.');
                e.preventDefault();
                return false;
            }

            // Kiểm tra các trường bắt buộc
            if (!ngayTruc) {
                alert('Vui lòng chọn ngày trực.');
                e.preventDefault();
                return false;
            }

            if (!caTruc) {
                alert('Vui lòng chọn ca trực.');
                e.preventDefault();
                return false;
            }

            if (!maNV) {
                alert('Vui lòng chọn nhân viên.');
                e.preventDefault();
                return false;
            }

            return true;
        }

        // Tự động sinh lại mã nếu có lỗi
        function retryGenerateMaLT() {
            if (!$('#hiddenMaLT').val()) {
                generateMaLT();
            }
        }

        // Thử lại mỗi 2 giây nếu chưa có mã
        setInterval(retryGenerateMaLT, 2000);
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .form-label {
            font-weight: 500;
        }

        .card-title {
            font-weight: 600;
        }

        #autoGeneratedCode {
            font-weight: bold;
            color: #0d6efd;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
    </style>
}