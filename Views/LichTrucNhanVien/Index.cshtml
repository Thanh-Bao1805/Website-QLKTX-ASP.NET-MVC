@model IEnumerable<DoAnCoSo.Models.LichTrucNhanVien>
@{
    ViewData["Title"] = "Quản Lý Lịch Trực Nhân Viên";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-calendar-alt me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Add" class="btn btn-light">
                    <i class="fas fa-plus me-2"></i>Thêm lịch trực
                </a>
            </div>
        </div>

        <div class="card-body p-0">
            <!-- Hiển thị thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-calendar-times fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Chưa có lịch trực nào</h5>
                    <p class="text-muted">Hãy thêm lịch trực mới để bắt đầu quản lý</p>
                    <a asp-action="Add" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Thêm lịch trực đầu tiên
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã LT</th>
                                <th>Nhân viên</th>
                                <th>Ngày trực</th>
                                <th>Ca trực</th>
                                <th>Thứ</th>
                                <th width="150">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">@item.MaLT</span>
                                    </td>
                                    <td>
                                        <div class="fw-bold">@item.NhanVien?.HoTen</div>
                                        <small class="text-muted">@item.MaNV</small>
                                    </td>
                                    <td>@item.NgayTruc.ToString("dd/MM/yyyy")</td>
                                    <td>
                                        @{
                                            var badgeClass = item.CaTruc switch
                                            {
                                                "Sáng" => "bg-info",
                                                "Chiều" => "bg-warning",
                                                "Tối" => "bg-dark",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@item.CaTruc</span>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark">@item.NgayTruc.DayOfWeek</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Display" asp-route-id="@item.MaLT" class="btn btn-outline-primary" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Update" asp-route-id="@item.MaLT" class="btn btn-outline-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaLT" class="btn btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Thống kê -->
        @if (Model.Any())
        {
            <div class="card-footer bg-light">
                <div class="row text-center">
                    <div class="col-md-3">
                        <span class="fw-bold text-primary">@Model.Count()</span>
                        <small class="text-muted">Tổng số</small>
                    </div>
                    <div class="col-md-3">
                        <span class="fw-bold text-info">@Model.Count(lt => lt.CaTruc == "Sáng")</span>
                        <small class="text-muted">Ca sáng</small>
                    </div>
                    <div class="col-md-3">
                        <span class="fw-bold text-warning">@Model.Count(lt => lt.CaTruc == "Chiều")</span>
                        <small class="text-muted">Ca chiều</small>
                    </div>
                    <div class="col-md-3">
                        <span class="fw-bold text-dark">@Model.Count(lt => lt.CaTruc == "Tối")</span>
                        <small class="text-muted">Ca tối</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .table th {
            border-top: none;
            font-weight: 600;
            color: #495057;
        }

        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .btn-group .btn {
            border-radius: 5px;
            margin: 0 2px;
        }

        .badge {
            font-size: 0.75em;
        }
    </style>
}