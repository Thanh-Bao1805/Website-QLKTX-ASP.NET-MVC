@model DoAnCoSo.Models.LichTrucNhanVien
@{
    ViewData["Title"] = "Cập nhật Lịch Trực";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-edit me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Hiển thị thông báo -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Update" method="post" id="lichTrucForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <div class="row g-4">
                    <!-- Thông tin lịch trực -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-warning">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin lịch trực
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label fw-bold">Mã lịch trực</label>
                                            <input asp-for="MaLT" class="form-control bg-light" readonly />
                                            <small class="form-text text-muted">Mã lịch trực không thể thay đổi</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayTruc" class="form-label fw-bold">Ngày trực *</label>
                                            <input asp-for="NgayTruc" type="date" class="form-control" required />
                                            <span asp-validation-for="NgayTruc" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="CaTruc" class="form-label fw-bold">Ca trực *</label>
                                            <select asp-for="CaTruc" class="form-select" required>
                                                <option value="">-- Chọn ca trực --</option>
                                                <option value="Sáng">Ca sáng (7h - 12h)</option>
                                                <option value="Chiều">Ca chiều (13h - 18h)</option>
                                                <option value="Tối">Ca tối (19h - 22h)</option>
                                            </select>
                                            <span asp-validation-for="CaTruc" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaNV" class="form-label fw-bold">Nhân viên *</label>
                                            <select asp-for="MaNV" class="form-select" required>
                                                <option value="">-- Chọn nhân viên --</option>
                                                @foreach (var nv in ViewBag.NhanViens)
                                                {
                                                    <option value="@nv.Value" selected="@(nv.Value == Model.MaNV)">@nv.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaNV" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .form-label {
            font-weight: 500;
        }

        .card-title {
            font-weight: 600;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }
    </style>
}