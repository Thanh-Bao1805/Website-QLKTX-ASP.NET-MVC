@model DoAnCoSo.Models.HoaDon
@{
    ViewData["Title"] = "Thanh toán thành công";
}

<div class="container-fluid px-4 py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card shadow-sm border-success mb-4">
                <div class="card-header bg-success text-white py-3 text-center">
                    <h4 class="mb-0">
                        <i class="fas fa-check-circle me-2"></i>Thanh Toán Thành Công!
                    </h4>
                </div>
                <div class="card-body p-4 text-center">
                    <p class="lead mb-3">Cảm ơn bạn đã thanh toán hóa đơn.</p>
                    <p class="fs-5 mb-4">Hóa đơn của bạn với mã <span class="fw-bold text-primary">#@Model.MaHoaDon</span> đã được thanh toán thành công!</p>
                    
                    <div class="alert alert-info border-0 mb-4" role="alert">
                        <i class="fas fa-info-circle me-2"></i>
                        Hệ thống sẽ cập nhật trạng thái hóa đơn trong vòng 2-5 phút.
                    </div>

                    <p class="mb-4">
                        Bạn có thể xem lại chi tiết hóa đơn hoặc quay lại trang danh sách hóa đơn.
                    </p>

                    <div class="d-grid gap-2 col-md-8 mx-auto">
                        <a asp-action="OrderDetail" asp-controller="Payment" asp-route-id="@Model.MaHoaDon" class="btn btn-primary btn-lg">
                            <i class="fas fa-file-invoice me-2"></i>Xem chi tiết hóa đơn
                        </a>
                        <a asp-action="Index" asp-controller="HoaDon" class="btn btn-outline-secondary btn-lg">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách hóa đơn
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card-header h4 {
            font-weight: 700;
        }
    </style>
} 