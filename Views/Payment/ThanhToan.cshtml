@model DoAnCoSo.Models.HoaDon

<div class="modal-dialog modal-dialog-centered" role="document">
    <div class="modal-content">
        <div class="modal-header border-0">
            <h5 class="modal-title fs-4 fw-bold">Thanh toán</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body pt-0">
            <form asp-action="OrderDetail" asp-controller="Payment" method="get">
                <input type="hidden" name="id" value="@Model.MaHoaDon" />
                <h6 class="text-primary mb-3">Phương thức thanh toán</h6>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="bankTransfer" checked>
                    <label class="form-check-label" for="bankTransfer">
                        Chuyển Khoản Ngân Hàng/Internet Banking
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="momo">
                    <label class="form-check-label" for="momo">
                        Ví MOMO
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="viettelMoney">
                    <label class="form-check-label" for="viettelMoney">
                        Ví Viettel Money
                    </label>
                </div>
                <div class="form-check mb-2">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="atmCard">
                    <label class="form-check-label" for="atmCard">
                        Thẻ ATM/Thẻ Nội Địa
                    </label>
                </div>
                <div class="form-check mb-4">
                    <input class="form-check-input" type="radio" name="paymentMethod" id="visaMastercard">
                    <label class="form-check-label" for="visaMastercard">
                        Thẻ Visa/MasterCard/JCB/American Express
                        <span class="text-danger">(Phí giao dịch: 8.000 VNĐ)</span>
                    </label>
                </div>

                <h6 class="text-primary mb-3">Đơn hàng</h6>
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <span>Hóa đơn số: @Model.MaHoaDon</span>
                    <span>@Model.LoaiChiPhi</span>
                    <span class="fw-bold">@Model.TongTien.ToString("N0") VNĐ</span>
                </div>

                <hr>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h6 class="mb-0">Tổng tiền</h6>
                    <span class="fs-5 fw-bold text-primary">@Model.TongTien.ToString("N0") VNĐ</span>
                </div>

                <h6 class="text-primary mb-3">Thông tin người mua</h6>
                <p class="text-muted small">Sử dụng tại <span class="text-danger">Khu B - ĐHQG Tp.HCM</span></p>
                <div class="mb-3">
                    <input type="text" class="form-control bg-light" value="@Model.SinhVien?.HoTen" readonly>
                </div>
                <div class="mb-3">
                    <input type="text" class="form-control bg-light" value="@Model.SinhVien?.SDT" readonly>
                </div>
                <div class="mb-3">
                    <input type="email" class="form-control bg-light" value="@Model.SinhVien?.Email" readonly>
                </div>

                <div class="form-check mb-4">
                    <input class="form-check-input" type="checkbox" id="agreeTerms" checked>
                    <label class="form-check-label" for="agreeTerms">
                        Tôi đồng ý <a href="#" class="text-primary text-decoration-none">các điều khoản và và điều kiện</a>.
                    </label>
                </div>

                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-lg">Tiếp tục thanh toán</button>
                </div>
            </form>
        </div>
    </div>
</div> 