@{
    ViewData["Title"] = "Quản lý chat với sinh viên";
}

<div class="card">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0"><i class="fas fa-comments me-2"></i>Danh sách sinh viên đang chat</h5>
    </div>
    <div class="card-body">
        @if (ViewBag.Users != null && ((IEnumerable<string>)ViewBag.Users).Any())
        {
            <div class="list-group">
                @foreach (var user in ViewBag.Users)
                {
                    <a href="@Url.Action("ChatWithStudent", new { id = user })"
                       class="list-group-item list-group-item-action d-flex justify-content-between align-items-center">
                        <div>
                            <i class="fas fa-user me-2"></i>
                            <strong>@user</strong>
                        </div>
                        <span class="badge bg-primary rounded-pill"><i class="fas fa-arrow-right"></i></span>
                    </a>
                }
            </div>
        }
        else
        {
            <div class="alert alert-info">
                <i class="fas fa-info-circle me-2"></i>Chưa có sinh viên nào chat với Admin.
            </div>
        }
    </div>
</div>