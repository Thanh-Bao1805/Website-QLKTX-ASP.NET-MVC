@model DoAnCoSo.Models.PhieuDuyet
@{
    ViewData["Title"] = "Thêm Phiếu Duyệt";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-file-plus me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-light">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Hiển thị thông báo -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Add" method="post" id="phieuDuyetForm">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <!-- THÊM HIDDEN FIELD CHO MaPhieu -->
                <input type="hidden" asp-for="MaPhieu" id="hiddenMaPhieu" />

                <div class="row g-4">
                    <!-- Thông tin phiếu duyệt -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-primary">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin phiếu duyệt
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label fw-bold">Mã phiếu (tự động)</label>
                                            <input type="text" class="form-control bg-light" id="autoGeneratedCode"
                                                   value="Đang sinh mã..." readonly />
                                            <small class="form-text text-muted">Mã sẽ được tự động sinh: PD001, PD002, ...</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayDuyet" class="form-label fw-bold">Ngày duyệt *</label>
                                            <input asp-for="NgayDuyet" type="date" class="form-control" required />
                                            <span asp-validation-for="NgayDuyet" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái *</label>
                                            <select asp-for="TrangThai" class="form-select" required>
                                                <option value="">-- Chọn trạng thái --</option>
                                                <option value="Chờ duyệt">Chờ duyệt</option>
                                                <option value="Đã duyệt">Đã duyệt</option>
                                                <option value="Từ chối">Từ chối</option>
                                            </select>
                                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin liên quan -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-success">
                                    <i class="fas fa-link me-2"></i>Thông tin liên quan
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaQTV" class="form-label fw-bold">Quản trị viên *</label>
                                            <select asp-for="MaQTV" class="form-select" required>
                                                <option value="">-- Chọn QTV --</option>
                                                @foreach (var qtv in ViewBag.QuanTriViens)
                                                {
                                                    <option value="@qtv.Value">@qtv.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaQTV" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaDK" class="form-label fw-bold">Mã đăng ký *</label>
                                            <select asp-for="MaDK" class="form-select" required>
                                                <option value="">-- Chọn mã đăng ký --</option>
                                                @foreach (var dk in ViewBag.DangKyOs)
                                                {
                                                    <option value="@dk.Value">@dk.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaDK" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success px-4" id="submitButton">
                        <i class="fas fa-save me-2"></i>Lưu phiếu duyệt
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Tự động sinh mã khi trang load
            generateMaPhieu();

            // Xử lý sự kiện submit form
            $('#phieuDuyetForm').on('submit', function (e) {
                return validateForm(e);
            });
        });

        // Hàm sinh mã phiếu
        function generateMaPhieu() {
            $('#autoGeneratedCode').val('Đang sinh mã...');
            $('#submitButton').prop('disabled', true);

            $.get('@Url.Action("GenerateMaPhieu", "PhieuDuyet")')
                .done(function (data) {
                    if (data.success) {
                        $('#autoGeneratedCode').val(data.maPhieu);
                        $('#hiddenMaPhieu').val(data.maPhieu);
                        $('#submitButton').prop('disabled', false);
                    } else {
                        $('#autoGeneratedCode').val('Lỗi khi sinh mã');
                        $('#submitButton').prop('disabled', true);
                    }
                })
                .fail(function () {
                    $('#autoGeneratedCode').val('Lỗi kết nối');
                    $('#submitButton').prop('disabled', true);
                });
        }

        // Hàm validate form
        function validateForm(e) {
            var maPhieu = $('#hiddenMaPhieu').val();

            if (!maPhieu || maPhieu === '') {
                alert('Mã phiếu chưa được sinh. Vui lòng đợi hoặc tải lại trang.');
                e.preventDefault();
                return false;
            }

            return true;
        }

        // Tự động sinh lại mã nếu có lỗi
        function retryGenerateMaPhieu() {
            if (!$('#hiddenMaPhieu').val()) {
                generateMaPhieu();
            }
        }

        // Thử lại mỗi 2 giây nếu chưa có mã
        setInterval(retryGenerateMaPhieu, 2000);
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .form-label {
            font-weight: 500;
        }

        .card-title {
            font-weight: 600;
        }

        #autoGeneratedCode {
            font-weight: bold;
            color: #0d6efd;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }

        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
        }
    </style>
}