@model DoAnCoSo.Models.PhieuDuyet
@{
    ViewData["Title"] = "Xóa Phiếu Duyệt";
}

<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>@ViewData["Title"]
                        </h5>
                        <a asp-action="Index" class="btn btn-light btn-sm">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </div>

                <div class="card-body text-center py-4">
                    <div class="mb-4">
                        <i class="fas fa-trash-alt fa-4x text-danger mb-3"></i>
                        <h4 class="text-danger">Bạn có chắc chắn muốn xóa?</h4>
                        <p class="text-muted">Thao tác này không thể hoàn tác. Phiếu duyệt sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
                    </div>

                    <!-- Thông tin phiếu duyệt -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="row text-start">
                                <div class="col-md-6 mb-3">
                                    <strong>Mã phiếu:</strong>
                                    <br>
                                    <span class="badge bg-secondary fs-6">@Model.MaPhieu</span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong>Trạng thái:</strong>
                                    <br>
                                    @{
                                        var badgeClass = Model.TrangThai switch
                                        {
                                            "Đã duyệt" => "bg-success",
                                            "Chờ duyệt" => "bg-warning",
                                            "Từ chối" => "bg-danger",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@Model.TrangThai</span>
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong>Ngày duyệt:</strong>
                                    <br>
                                    @Model.NgayDuyet.ToString("dd/MM/yyyy")
                                </div>
                                <div class="col-md-6 mb-3">
                                    <strong>Mã đăng ký:</strong>
                                    <br>
                                    <span class="badge bg-info">@Model.MaDK</span>
                                </div>
                                <div class="col-12 mb-3">
                                    <strong>Quản trị viên:</strong>
                                    <br>
                                    <span class="fw-bold">@Model.QuanTriVien?.HoTen</span>
                                    <br>
                                    <small class="text-muted">@Model.MaQTV</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Form xóa -->
                    <form asp-action="DeleteConfirmed" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.MaPhieu" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-secondary px-4">
                                <i class="fas fa-times me-2"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash me-2"></i>Xác nhận xóa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .badge {
            font-size: 0.8em;
            padding: 0.5em 0.75em;
        }

        .fs-6 {
            font-size: 1.1rem !important;
        }
    </style>
}