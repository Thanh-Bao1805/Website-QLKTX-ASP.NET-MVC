@model DoAnCoSo.Models.PhieuDuyet
@{
    ViewData["Title"] = "Cập nhật Phiếu Duyệt";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-edit me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Hiển thị thông báo -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Update" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <div class="row g-4">
                    <!-- Thông tin phiếu duyệt -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-warning">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin phiếu duyệt
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label fw-bold">Mã phiếu</label>
                                            <input asp-for="MaPhieu" class="form-control bg-light" readonly />
                                            <small class="form-text text-muted">Mã phiếu không thể thay đổi</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayDuyet" class="form-label fw-bold">Ngày duyệt *</label>
                                            <input asp-for="NgayDuyet" type="date" class="form-control" required />
                                            <span asp-validation-for="NgayDuyet" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái *</label>
                                            <select asp-for="TrangThai" class="form-select" required>
                                                <option value="">-- Chọn trạng thái --</option>
                                                <option value="Chờ duyệt">Chờ duyệt</option>
                                                <option value="Đã duyệt">Đã duyệt</option>
                                                <option value="Từ chối">Từ chối</option>
                                            </select>
                                            <span asp-validation-for="TrangThai" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin liên quan -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-success">
                                    <i class="fas fa-link me-2"></i>Thông tin liên quan
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaQTV" class="form-label fw-bold">Quản trị viên *</label>
                                            <select asp-for="MaQTV" class="form-select" required>
                                                <option value="">-- Chọn QTV --</option>
                                                @foreach (var qtv in ViewBag.QuanTriViens)
                                                {
                                                    <option value="@qtv.Value" selected="@(qtv.Value == Model.MaQTV)">@qtv.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaQTV" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaDK" class="form-label fw-bold">Mã đăng ký *</label>
                                            <select asp-for="MaDK" class="form-select" required>
                                                <option value="">-- Chọn mã đăng ký --</option>
                                                @foreach (var dk in ViewBag.DangKyOs)
                                                {
                                                    <option value="@dk.Value" selected="@(dk.Value == Model.MaDK)">@dk.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaDK" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .form-label {
            font-weight: 500;
        }

        .card-title {
            font-weight: 600;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }
    </style>
}