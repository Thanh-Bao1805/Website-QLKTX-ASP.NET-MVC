@model DoAnCoSo.Models.Phong

@{
    ViewData["Title"] = "Chi Tiết Phòng " + Model.MaPhong;
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h2 class="card-title mb-0">@ViewData["Title"]</h2>
            <div>
                <a asp-action="Index" class="btn btn-light">
                    <i class="fas fa-arrow-left me-2"></i>Quay Lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title mb-3">
                                <i class="fas fa-info-circle me-2"></i>Thông Tin Cơ Bản
                            </h5>
                            <div class="list-group list-group-flush">
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-hashtag me-2"></i>Mã Phòng</span>
                                    <strong>@Model.MaPhong</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-venus-mars me-2"></i>Loại Phòng</span>
                                    <strong>@Model.LoaiPhong</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-restroom me-2"></i>Giới tính phòng</span>
                                    <strong>@Model.GioiTinhPhong</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-building me-2"></i>Tòa</span>
                                    <strong>@Model.Toa?.TenToa</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-bed me-2"></i>Số Giường</span>
                                    <strong>@Model.SoGiuong</strong>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title mb-3">
                                <i class="fas fa-users me-2"></i>Thông Tin Sử Dụng
                            </h5>
                            <div class="list-group list-group-flush">
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-user-friends me-2"></i>Số SV Tối Đa</span>
                                    <strong>@Model.SoSinhVienToiDa người</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-user-check me-2"></i>Số SV Hiện Tại</span>
                                    <strong>@Model.SoSinhVienHienTai người</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-percentage me-2"></i>Tỷ Lệ Lấp Đầy</span>
                                    <div class="progress" style="width: 100px;">
                                        @{
                                            var occupancyRate = (Model.SoSinhVienHienTai * 100.0) / Model.SoSinhVienToiDa;
                                            var bgColor = occupancyRate >= 90 ? "bg-danger" :
                                                         occupancyRate >= 70 ? "bg-warning" : "bg-success";
                                        }
                                        <div class="progress-bar @bgColor" role="progressbar" 
                                             style="width: @occupancyRate%;" 
                                             aria-valuenow="@occupancyRate" aria-valuemin="0" aria-valuemax="100">
                                            @occupancyRate.ToString("F0")%
                                        </div>
                                    </div>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-circle me-2"></i>Trạng Thái</span>
                                    <span class="badge @(Model.TrangThai == "Trống" ? "bg-success" : 
                                                       Model.TrangThai == "Đang sử dụng" ? "bg-primary" : 
                                                       "bg-warning")">
                                        @Model.TrangThai
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card mb-3">
                        <div class="card-body">
                            <h5 class="card-title mb-3">
                                <i class="fas fa-money-bill me-2"></i>Thông Tin Tài Chính
                            </h5>
                            <div class="list-group list-group-flush">
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-money-bill-wave me-2"></i>Giá Phòng</span>
                                    <strong class="text-primary">@Model.GiaPhong.ToString("N0") đ/tháng</strong>
                                </div>
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <span><i class="fas fa-hand-holding-usd me-2"></i>Tiền Cọc</span>
                                    <strong class="text-success">@Model.TienCoc.ToString("N0") đ</strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title mb-3">
                                <i class="fas fa-image me-2"></i>Hình Ảnh Phòng
                            </h5>
                            @if (!string.IsNullOrEmpty(Model.ImageUrl))
                            {
                                <img src="@Model.ImageUrl" alt="Hình ảnh phòng" class="img-fluid rounded" />
                            }
                            else
                            {
                                <div class="alert alert-info mb-0">
                                    <i class="fas fa-info-circle me-2"></i>Chưa có hình ảnh
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>