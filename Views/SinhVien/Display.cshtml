@model DoAnCoSo.Models.SinhVien

@{
    ViewData["Title"] = "Chi tiết sinh viên";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-user-graduate me-2"></i>@ViewData["Title"]
                </h5>
                <div>
                    <a asp-action="Update" asp-route-id="@Model.MaSV" class="btn btn-warning">
                        <i class="fas fa-edit me-2"></i>Cập nhật
                    </a>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="fas fa-arrow-left me-2"></i>Quay lại
                    </a>
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <!-- Thông tin cơ bản -->
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-body text-center">
                            <div class="avatar-circle-large bg-primary text-white mx-auto mb-3">
                                @Model.HoTen.First().ToString().ToUpper()
                            </div>
                            <h4 class="mb-1">@Model.HoTen</h4>
                            <p class="text-muted mb-3">
                                <i class="fas fa-id-card me-2"></i>@Model.MaSV
                            </p>
                            <hr />
                            <div class="text-start">
                                <p class="mb-2">
                                    <i class="fas fa-birthday-cake text-primary me-2"></i>
                                    <strong>Ngày sinh:</strong>
                                    @if (Model.NgaySinh != default(DateTime))
                                    {
                                        @Model.NgaySinh.ToString("dd/MM/yyyy")
                                    }
                                    else
                                    {
                                        <p>Chưa cập nhật</p>
                                    }
                                </p>
                                <p class="mb-2">
                                    <i class="fas fa-venus-mars text-primary me-2"></i>
                                    <strong>Giới tính:</strong> @Model.GioiTinh
                                </p>
                                <p class="mb-2">
                                    <i class="fas fa-id-badge text-primary me-2"></i>
                                    <strong>CCCD:</strong> @Model.CCCD
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Thông tin liên hệ -->
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light border-0">
                            <h6 class="mb-0">
                                <i class="fas fa-address-card me-2"></i>Thông tin liên hệ
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-4">
                                <p class="mb-2">
                                    <i class="fas fa-phone text-success me-2"></i>
                                    <strong>Số điện thoại:</strong>
                                </p>
                                <p class="ms-4">@Model.SDT</p>
                            </div>
                            <div class="mb-4">
                                <p class="mb-2">
                                    <i class="fas fa-envelope text-success me-2"></i>
                                    <strong>Email:</strong>
                                </p>
                                <p class="ms-4">@Model.Email</p>
                            </div>
                            <div>
                                <p class="mb-2">
                                    <i class="fas fa-map-marker-alt text-success me-2"></i>
                                    <strong>Địa chỉ thường trú:</strong>
                                </p>
                                <p class="ms-4">@Model.DiaChiThuongTru</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Thông tin học tập và KTX -->
                <div class="col-md-4 mb-4">
                    <div class="card h-100 border-0 shadow-sm">
                        <div class="card-header bg-light border-0">
                            <h6 class="mb-0">
                                <i class="fas fa-graduation-cap me-2"></i>Thông tin học tập & KTX
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-4">
                                <p class="mb-2">
                                    <i class="fas fa-university text-info me-2"></i>
                                    <strong>Khoa:</strong>
                                </p>
                                <p class="ms-4">@Model.Khoa</p>
                            </div>
                            <div class="mb-4">
                                <p class="mb-2">
                                    <i class="fas fa-users text-info me-2"></i>
                                    <strong>Lớp:</strong>
                                </p>
                                <p class="ms-4">@Model.Lop</p>
                            </div>
                            <div>
                                <p class="mb-2">
                                    <i class="fas fa-home text-info me-2"></i>
                                    <strong>Trạng thái KTX:</strong>
                                </p>
                                <div class="ms-4">
                                    @if (Model.NgayNhapKTX != default(DateTime))
                                    {
                                        <div class="badge bg-success p-2">
                                            <i class="fas fa-check-circle me-1"></i>
                                            Đang ở KTX (từ @Model.NgayNhapKTX.ToString("dd/MM/yyyy"))
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="badge bg-secondary p-2">
                                            <i class="fas fa-times-circle me-1"></i>
                                            Chưa ở KTX
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .avatar-circle-large {
            width: 100px;
            height: 100px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 2.5rem;
        }
    </style>
}