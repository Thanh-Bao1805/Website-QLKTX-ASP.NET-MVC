@model DoAnCoSo.Models.SuCoBaoTri
@{
    ViewData["Title"] = "Thêm sự cố bảo trì";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-plus me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Hiển thị thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Add" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <!-- THÊM HIDDEN FIELD CHO MaSuCo -->
                <input type="hidden" asp-for="MaSuCo" id="hiddenMaSuCo" />

                <div class="row g-4">
                    <!-- Thông tin cơ bản -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label">Mã sự cố (tự động)</label>
                                            <input type="text" class="form-control bg-light" id="autoGeneratedCode"
                                                   value="Hệ thống sẽ tự sinh mã" readonly />
                                            <small class="form-text text-muted">Mã sự cố sẽ được tự động sinh: SC001, SC002, ...</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayPhatHien" class="form-label">Ngày phát hiện *</label>
                                            <input asp-for="NgayPhatHien" type="date" class="form-control" required />
                                            <span asp-validation-for="NgayPhatHien" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="TinhTrang" class="form-label">Tình trạng *</label>
                                            <select asp-for="TinhTrang" class="form-select" required>
                                                <option value="">-- Chọn tình trạng --</option>
                                                <option value="Chờ xử lý">Chờ xử lý</option>
                                                <option value="Đang xử lý">Đang xử lý</option>
                                                <option value="Đã xử lý">Đã xử lý</option>
                                            </select>
                                            <span asp-validation-for="TinhTrang" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin vị trí -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3">
                                    <i class="fas fa-map-marker-alt me-2"></i>Thông tin vị trí
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaPhong" class="form-label">Phòng *</label>
                                            <select asp-for="MaPhong" class="form-select" required>
                                                <option value="">-- Chọn phòng --</option>
                                                @foreach (var phong in ViewBag.Phongs)
                                                {
                                                    <option value="@phong.Value">@phong.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaPhong" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaThietBi" class="form-label">Thiết bị</label>
                                            <select asp-for="MaThietBi" class="form-select">
                                                <option value="">-- Chọn thiết bị --</option>
                                                @foreach (var tb in ViewBag.ThietBis)
                                                {
                                                    <option value="@tb.Value">@tb.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaThietBi" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-primary" onclick="return validateForm()">
                        <i class="fas fa-save me-2"></i>Lưu sự cố
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script>
        $(document).ready(function () {
            // Tự động sinh mã sự cố khi trang load
            generateMaSuCo();

            // Validate form
            $('form').on('submit', function (e) {
                return validateForm();
            });
        });

        // Hàm sinh mã sự cố
        function generateMaSuCo() {
            $.get('@Url.Action("GenerateMaSuCo", "SuCoBaoTri")')
                .done(function (data) {
                    if (data.success) {
                        $('#autoGeneratedCode').val(data.maSuCo);
                        $('#hiddenMaSuCo').val(data.maSuCo);
                    } else {
                        $('#autoGeneratedCode').val('Lỗi khi sinh mã');
                    }
                })
                .fail(function () {
                    $('#autoGeneratedCode').val('Lỗi kết nối');
                });
        }

        // Hàm validate form
        function validateForm() {
            var maSuCo = $('#hiddenMaSuCo').val();

            if (!maSuCo || maSuCo === '') {
                alert('Mã sự cố chưa được sinh. Vui lòng thử lại.');
                return false;
            }

            return true;
        }
    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .form-label {
            font-weight: 500;
        }

        .card-title {
            font-weight: 600;
            color: #495057;
        }

        #autoGeneratedCode {
            font-weight: bold;
            color: #0d6efd;
        }
    </style>
}