@model DoAnCoSo.Models.SuCoBaoTri
@{
    ViewData["Title"] = "Xóa sự cố";
}

<div class="container-fluid px-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-danger text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-exclamation-triangle me-2"></i>@ViewData["Title"]
                        </h5>
                        <a asp-action="Index" class="btn btn-light btn-sm">
                            <i class="fas fa-arrow-left me-2"></i>Quay lại
                        </a>
                    </div>
                </div>

                <div class="card-body text-center py-4">
                    <div class="mb-4">
                        <i class="fas fa-trash-alt fa-4x text-danger mb-3"></i>
                        <h4 class="text-danger">Bạn có chắc chắn muốn xóa?</h4>
                        <p class="text-muted">Thao tác này không thể hoàn tác. Sự cố sẽ bị xóa vĩnh viễn khỏi hệ thống.</p>
                    </div>

                    <!-- Thông tin sự cố -->
                    <div class="card bg-light mb-4">
                        <div class="card-body">
                            <div class="row text-start">
                                <div class="col-md-6 mb-2">
                                    <strong>Mã sự cố:</strong>
                                    <br>
                                    <span class="badge bg-secondary">@Model.MaSuCo</span>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <strong>Ngày phát hiện:</strong>
                                    <br>
                                    @Model.NgayPhatHien.ToString("dd/MM/yyyy")
                                </div>
                                <div class="col-md-6 mb-2">
                                    <strong>Phòng:</strong>
                                    <br>
                                    <span class="badge bg-primary">@Model.Phong?.MaPhong</span>
                                </div>
                                <div class="col-md-6 mb-2">
                                    <strong>Tình trạng:</strong>
                                    <br>
                                    @{
                                        var badgeClass = Model.TinhTrang switch
                                        {
                                            "Chờ xử lý" => "bg-warning",
                                            "Đang xử lý" => "bg-info",
                                            "Đã xử lý" => "bg-success",
                                            _ => "bg-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass">@Model.TinhTrang</span>
                                </div>
                                @if (!string.IsNullOrEmpty(Model.ThietBi?.TenThietBi))
                                {
                                    <div class="col-12 mb-2">
                                        <strong>Thiết bị:</strong>
                                        <br>
                                        <span class="badge bg-info">@Model.ThietBi.TenThietBi</span>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- SỬA FORM ACTION -->
                    <form asp-action="DeleteConfirmed" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.MaSuCo" />

                        <div class="d-flex justify-content-center gap-3">
                            <a asp-action="Index" class="btn btn-secondary px-4">
                                <i class="fas fa-times me-2"></i>Hủy bỏ
                            </a>
                            <button type="submit" class="btn btn-danger px-4">
                                <i class="fas fa-trash me-2"></i>Xác nhận xóa
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .badge {
            font-size: 0.8em;
            padding: 0.5em 0.75em;
        }
    </style>
}