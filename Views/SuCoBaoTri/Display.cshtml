@model DoAnCoSo.Models.SuCoBaoTri
@{
    ViewData["Title"] = "Chi tiết sự cố";
}

<div class="container-fluid px-4">
    <div class="row">
        <div class="col-12">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">
                            <i class="fas fa-info-circle me-2"></i>@ViewData["Title"]
                        </h5>
                        <div>
                            <a asp-action="Index" class="btn btn-light btn-sm me-2">
                                <i class="fas fa-arrow-left me-2"></i>Quay lại
                            </a>
                            <a asp-action="Update" asp-route-id="@Model.MaSuCo" class="btn btn-warning btn-sm me-2">
                                <i class="fas fa-edit me-2"></i>Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@Model.MaSuCo" class="btn btn-danger btn-sm">
                                <i class="fas fa-trash me-2"></i>Xóa
                            </a>
                        </div>
                    </div>
                </div>

                <div class="card-body">
                    <div class="row">
                        <!-- Thông tin cơ bản -->
                        <div class="col-md-6">
                            <div class="card mb-4">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-info-circle me-2 text-primary"></i>Thông tin cơ bản
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Mã sự cố:</div>
                                        <div class="col-sm-8">
                                            <span class="badge bg-secondary fs-6">@Model.MaSuCo</span>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Ngày phát hiện:</div>
                                        <div class="col-sm-8">@Model.NgayPhatHien.ToString("dd/MM/yyyy")</div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Tình trạng:</div>
                                        <div class="col-sm-8">
                                            @{
                                                var badgeClass = Model.TinhTrang switch
                                                {
                                                    "Chờ xử lý" => "bg-warning",
                                                    "Đang xử lý" => "bg-info",
                                                    "Đã xử lý" => "bg-success",
                                                    _ => "bg-secondary"
                                                };
                                            }
                                            <span class="badge @badgeClass fs-6">@Model.TinhTrang</span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Thông tin vị trí -->
                        <div class="col-md-6">
                            <div class="card mb-4">
                                <div class="card-header bg-light">
                                    <h6 class="mb-0">
                                        <i class="fas fa-map-marker-alt me-2 text-success"></i>Thông tin vị trí
                                    </h6>
                                </div>
                                <div class="card-body">
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Phòng:</div>
                                        <div class="col-sm-8">
                                            <span class="badge bg-primary">@Model.Phong?.MaPhong</span>
                                        </div>
                                    </div>
                                    <div class="row mb-3">
                                        <div class="col-sm-4 fw-bold">Thiết bị:</div>
                                        <div class="col-sm-8">
                                            @if (!string.IsNullOrEmpty(Model.ThietBi?.TenThietBi))
                                            {
                                                <span class="badge bg-info">@Model.ThietBi.TenThietBi</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Không có</span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Timeline xử lý -->
                    <div class="card">
                        <div class="card-header bg-light">
                            <h6 class="mb-0">
                                <i class="fas fa-history me-2 text-info"></i>Lịch sử xử lý
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="timeline">
                                <div class="timeline-item">
                                    <div class="timeline-marker bg-primary"></div>
                                    <div class="timeline-content">
                                        <h6 class="mb-1">Sự cố được báo cáo</h6>
                                        <p class="text-muted mb-0">@Model.NgayPhatHien.ToString("dd/MM/yyyy HH:mm")</p>
                                        <p class="mt-2">Sự cố được phát hiện và báo cáo vào hệ thống</p>
                                    </div>
                                </div>

                                @if (Model.TinhTrang == "Đang xử lý" || Model.TinhTrang == "Đã xử lý")
                                {
                                    <div class="timeline-item">
                                        <div class="timeline-marker bg-info"></div>
                                        <div class="timeline-content">
                                            <h6 class="mb-1">Bắt đầu xử lý</h6>
                                            <p class="text-muted mb-0">@DateTime.Now.AddDays(-1).ToString("dd/MM/yyyy HH:mm")</p>
                                            <p class="mt-2">Nhân viên kỹ thuật đã tiếp nhận và bắt đầu xử lý sự cố</p>
                                        </div>
                                    </div>
                                }

                                @if (Model.TinhTrang == "Đã xử lý")
                                {
                                    <div class="timeline-item">
                                        <div class="timeline-marker bg-success"></div>
                                        <div class="timeline-content">
                                            <h6 class="mb-1">Hoàn thành xử lý</h6>
                                            <p class="text-muted mb-0">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
                                            <p class="mt-2">Sự cố đã được xử lý thành công</p>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .badge {
            font-size: 0.8em;
            padding: 0.5em 0.75em;
        }

        .timeline {
            position: relative;
            padding-left: 30px;
        }

        .timeline-item {
            position: relative;
            margin-bottom: 2rem;
        }

        .timeline-marker {
            position: absolute;
            left: -30px;
            top: 0;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            border: 3px solid white;
        }

        .timeline-content {
            padding: 1rem;
            background: #f8f9fa;
            border-radius: 8px;
            border-left: 4px solid #dee2e6;
        }

        .timeline-item:not(:last-child):before {
            content: '';
            position: absolute;
            left: -21px;
            top: 20px;
            bottom: -2rem;
            width: 2px;
            background: #dee2e6;
        }
    </style>
}