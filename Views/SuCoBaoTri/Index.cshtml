@model IEnumerable<DoAnCoSo.Models.SuCoBaoTri>
@{
    ViewData["Title"] = "Danh sách sự cố bảo trì";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-tools me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Add" class="btn btn-light">
                    <i class="fas fa-plus me-2"></i>Thêm sự cố
                </a>
            </div>
        </div>

        <!-- Bộ lọc tìm kiếm -->
        <div class="card-body border-bottom">
            <form method="get" class="row g-3">
                <div class="col-md-3">
                    <input type="text" name="searchString" value="@ViewBag.SearchString" class="form-control" placeholder="Tìm kiếm..." />
                </div>
                <div class="col-md-2">
                    <select name="maPhong" class="form-select">
                        <option value="">Tất cả phòng</option>
                        @foreach (var phong in ViewBag.Phongs)
                        {
                            <option value="@phong.Value" selected="@(ViewBag.MaPhong == phong.Value)">@phong.Text</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="tinhTrang" class="form-select">
                        <option value="">Tất cả tình trạng</option>
                        <option value="Chờ xử lý" selected="@(ViewBag.TinhTrang == "Chờ xử lý")">Chờ xử lý</option>
                        <option value="Đang xử lý" selected="@(ViewBag.TinhTrang == "Đang xử lý")">Đang xử lý</option>
                        <option value="Đã xử lý" selected="@(ViewBag.TinhTrang == "Đã xử lý")">Đã xử lý</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <input type="date" name="tuNgay" value="@ViewBag.TuNgay" class="form-control" />
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary me-2">
                        <i class="fas fa-search me-2"></i>Tìm kiếm
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">Reset</a>
                </div>
            </form>
        </div>

        <div class="card-body p-0">
            <!-- Hiển thị thông báo -->
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-3" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (!Model.Any())
            {
                <div class="text-center py-5">
                    <i class="fas fa-inbox fa-3x text-muted mb-3"></i>
                    <h5 class="text-muted">Không có sự cố nào</h5>
                    <p class="text-muted">Hãy thêm sự cố mới để bắt đầu quản lý</p>
                    <a asp-action="Add" class="btn btn-primary">
                        <i class="fas fa-plus me-2"></i>Thêm sự cố đầu tiên
                    </a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Mã sự cố</th>
                                <th>Ngày phát hiện</th>
                                <th>Phòng</th>
                                <th>Thiết bị</th>
                                <th>Tình trạng</th>
                                <th width="150">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-secondary">@item.MaSuCo</span>
                                    </td>
                                    <td>@item.NgayPhatHien.ToString("dd/MM/yyyy")</td>
                                    <td>@item.Phong?.MaPhong</td>
                                    <td>@item.ThietBi?.TenThietBi</td>
                                    <td>
                                        @{
                                            var badgeClass = item.TinhTrang switch
                                            {
                                                "Chờ xử lý" => "bg-warning",
                                                "Đang xử lý" => "bg-info",
                                                "Đã xử lý" => "bg-success",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@item.TinhTrang</span>
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <a asp-action="Display" asp-route-id="@item.MaSuCo" class="btn btn-outline-primary" title="Xem chi tiết">
                                                <i class="fas fa-eye"></i>
                                            </a>
                                            <a asp-action="Update" asp-route-id="@item.MaSuCo" class="btn btn-outline-warning" title="Sửa">
                                                <i class="fas fa-edit"></i>
                                            </a>
                                            <a asp-action="Delete" asp-route-id="@item.MaSuCo" class="btn btn-outline-danger" title="Xóa">
                                                <i class="fas fa-trash"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>

        <!-- Thống kê -->
        @if (Model.Any())
        {
            <div class="card-footer bg-light">
                <div class="row text-center">
                    <div class="col-md-4">
                        <span class="badge bg-warning">@Model.Count(s => s.TinhTrang == "Chờ xử lý")</span>
                        <small class="text-muted">Chờ xử lý</small>
                    </div>
                    <div class="col-md-4">
                        <span class="badge bg-info">@Model.Count(s => s.TinhTrang == "Đang xử lý")</span>
                        <small class="text-muted">Đang xử lý</small>
                    </div>
                    <div class="col-md-4">
                        <span class="badge bg-success">@Model.Count(s => s.TinhTrang == "Đã xử lý")</span>
                        <small class="text-muted">Đã xử lý</small>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Styles {
    <style>
        .table th {
            border-top: none;
            font-weight: 600;
            color: #495057;
        }

        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .btn-group .btn {
            border-radius: 5px;
            margin: 0 2px;
        }

        .badge {
            font-size: 0.75em;
        }
    </style>
}