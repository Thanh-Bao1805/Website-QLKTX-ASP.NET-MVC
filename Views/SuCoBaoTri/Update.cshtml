@model DoAnCoSo.Models.SuCoBaoTri
@{
    ViewData["Title"] = "Cập nhật sự cố";
}

<div class="container-fluid px-4">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-warning text-dark py-3">
            <div class="d-flex justify-content-between align-items-center">
                <h5 class="mb-0">
                    <i class="fas fa-edit me-2"></i>@ViewData["Title"]
                </h5>
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <!-- Hiển thị thông báo -->
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <form asp-action="Update" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-4" role="alert"></div>

                <div class="row g-4">
                    <!-- Thông tin cơ bản -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-warning">
                                    <i class="fas fa-info-circle me-2"></i>Thông tin cơ bản
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label class="form-label fw-bold">Mã sự cố</label>
                                            <input asp-for="MaSuCo" class="form-control bg-light" readonly />
                                            <small class="form-text text-muted">Mã sự cố không thể thay đổi</small>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="NgayPhatHien" class="form-label fw-bold">Ngày phát hiện *</label>
                                            <input asp-for="NgayPhatHien" type="date" class="form-control" required />
                                            <span asp-validation-for="NgayPhatHien" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="TinhTrang" class="form-label fw-bold">Tình trạng *</label>
                                            <select asp-for="TinhTrang" class="form-select" required>
                                                <option value="">-- Chọn tình trạng --</option>
                                                <option value="Chờ xử lý">Chờ xử lý</option>
                                                <option value="Đang xử lý">Đang xử lý</option>
                                                <option value="Đã xử lý">Đã xử lý</option>
                                            </select>
                                            <span asp-validation-for="TinhTrang" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Thông tin vị trí -->
                    <div class="col-12">
                        <div class="card bg-light">
                            <div class="card-body">
                                <h6 class="card-title mb-3 text-warning">
                                    <i class="fas fa-map-marker-alt me-2"></i>Thông tin vị trí
                                </h6>
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaPhong" class="form-label fw-bold">Phòng *</label>
                                            <select asp-for="MaPhong" class="form-select" required>
                                                <option value="">-- Chọn phòng --</option>
                                                @foreach (var phong in ViewBag.Phongs)
                                                {
                                                    <option value="@phong.Value" selected="@(phong.Value == Model.MaPhong)">@phong.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaPhong" class="text-danger"></span>
                                        </div>
                                    </div>
                                    <div class="col-md-6">
                                        <div class="form-group">
                                            <label asp-for="MaThietBi" class="form-label fw-bold">Thiết bị</label>
                                            <select asp-for="MaThietBi" class="form-select">
                                                <option value="">-- Chọn thiết bị --</option>
                                                @foreach (var tb in ViewBag.ThietBis)
                                                {
                                                    <option value="@tb.Value" selected="@(tb.Value == Model.MaThietBi)">@tb.Text</option>
                                                }
                                            </select>
                                            <span asp-validation-for="MaThietBi" class="text-danger"></span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-warning px-4">
                        <i class="fas fa-save me-2"></i>Cập nhật
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

@section Styles {
    <style>
        .card {
            border-radius: 10px;
            overflow: hidden;
        }

        .form-label {
            font-weight: 500;
        }

        .card-title {
            font-weight: 600;
        }

        .bg-light {
            background-color: #f8f9fa !important;
        }
    </style>
}