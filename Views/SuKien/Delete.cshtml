@model DoAnCoSo.Models.SuKien
@{
    ViewData["Title"] = "Xác nhận xóa sự kiện";
}

<div class="container-fluid">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="card shadow-sm border-danger">
                <div class="card-body">
                    <div class="text-center mb-4">
                        <div class="warning-icon mb-3">
                            <i class="fas fa-exclamation-triangle"></i>
                        </div>
                        <h2 class="card-title text-danger">
                            Xác nhận xóa sự kiện
                        </h2>
                        <p class="text-muted">
                            Bạn có chắc chắn muốn xóa sự kiện này? Hành động này không thể hoàn tác.
                        </p>
                    </div>

                    <div class="event-details p-4 bg-light rounded-3 mb-4">
                        <div class="row g-3">
                            <div class="col-12">
                                <h5 class="text-primary mb-0">
                                    <i class="fas fa-calendar-day me-2"></i>@Model.TenSuKien
                                </h5>
                                <span class="badge bg-primary mt-2">@Model.MaSuKien</span>
                            </div>
                            
                            <div class="col-12 col-md-6">
                                <p class="mb-1 text-muted">
                                    <i class="fas fa-calendar me-2"></i>Ngày tổ chức:
                                </p>
                                <p class="mb-0 fw-bold">@Model.NgayToChuc.ToString("dd/MM/yyyy")</p>
                            </div>

                            <div class="col-12 col-md-6">
                                <p class="mb-1 text-muted">
                                    <i class="fas fa-map-marker-alt me-2"></i>Địa điểm:
                                </p>
                                <p class="mb-0 fw-bold">@Model.DiaDiem</p>
                            </div>

                            <div class="col-12">
                                <p class="mb-1 text-muted">
                                    <i class="fas fa-user-shield me-2"></i>Quản trị viên phụ trách:
                                </p>
                                <p class="mb-0 fw-bold">@(Model.QuanTriVien?.HoTen ?? "Chưa phân công")</p>
                            </div>
                        </div>
                    </div>

                    <form asp-action="Delete" method="post" class="text-center">
                        <input type="hidden" asp-for="MaSuKien" />
                        <a asp-action="Index" class="btn btn-outline-secondary me-2">
                            <i class="fas fa-times me-2"></i>Hủy bỏ
                        </a>
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash-alt me-2"></i>Xác nhận xóa
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        border-radius: 10px;
        border-width: 2px;
    }

    .warning-icon {
        width: 80px;
        height: 80px;
        margin: 0 auto;
        background-color: #fff3cd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .warning-icon i {
        font-size: 2.5rem;
        color: #dc3545;
    }

    .event-details {
        border: 1px solid rgba(0,0,0,.125);
    }

    .badge {
        font-size: 0.9rem;
        padding: 0.5em 1em;
        border-radius: 6px;
    }

    .btn {
        padding: 0.5rem 1.5rem;
        border-radius: 6px;
    }
</style>
