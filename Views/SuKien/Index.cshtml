@model IEnumerable<DoAnCoSo.Models.SuKien>
@{
    ViewData["Title"] = "Danh sách sự kiện";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="text-primary">
                <i class="fas fa-calendar-day me-2"></i>@ViewData["Title"]
            </h2>
            <p class="text-muted">Quản lý các sự kiện trong ký túc xá</p>
        </div>
         @if (User.IsInRole("Admin"))
                                {
        <a asp-action="Add" class="btn btn-primary">
            <i class="fas fa-plus-circle me-2"></i>Thêm sự kiện mới
        </a>
        }
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row g-4">
        @foreach (var suKien in Model)
        {
            <div class="col-12 col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm hover-shadow">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title text-primary mb-0">@suKien.TenSuKien</h5>
                            <span class="badge bg-primary">@suKien.MaSuKien</span>
                        </div>
                        <div class="mb-3">
                            <p class="card-text mb-1">
                                <i class="fas fa-calendar me-2 text-muted"></i>
                                @suKien.NgayToChuc.ToString("dd/MM/yyyy")
                            </p>
                            <p class="card-text mb-1">
                                <i class="fas fa-map-marker-alt me-2 text-muted"></i>
                                @suKien.DiaDiem
                            </p>
                            <p class="card-text">
                                <i class="fas fa-user me-2 text-muted"></i>
                                @(suKien.QuanTriVien?.HoTen ?? "Chưa phân công")
                            </p>
                        </div>
                        <div class="btn-group w-100">
                            <a asp-action="Display" asp-route-id="@suKien.MaSuKien" 
                               class="btn btn-outline-primary">
                                <i class="fas fa-eye me-1"></i>Chi tiết
                            </a>
                             @if (User.IsInRole("Admin"))
                                {
                            <a asp-action="Update" asp-route-id="@suKien.MaSuKien" 
                               class="btn btn-outline-warning">
                                <i class="fas fa-edit me-1"></i>Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@suKien.MaSuKien" 
                               class="btn btn-outline-danger">
                                <i class="fas fa-trash-alt me-1"></i>Xóa
                            </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    .hover-shadow {
        transition: all 0.3s ease;
    }
    
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.15) !important;
    }
    
    .card {
        border: none;
        border-radius: 10px;
        overflow: hidden;
    }
    
    .btn-group .btn {
        border-radius: 6px;
        margin: 0 2px;
    }
    
    .badge {
        font-size: 0.8rem;
        padding: 0.5em 0.8em;
        border-radius: 6px;
    }
</style>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Tự động ẩn alert sau 5 giây
            setTimeout(function() {
                $('.alert').alert('close');
            }, 5000);
        });
    </script>
}
