@model DoAnCoSo.Models.ViPham
@{
    ViewData["Title"] = "Xóa vi phạm";
}

<div class="container-fluid px-4">
    <div class="card mb-4">
        <div class="card-header">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <i class="fas fa-trash-alt me-1"></i>
                    @ViewData["Title"]
                </div>
                <a asp-action="Index" class="btn btn-outline-primary">
                    <i class="fas fa-arrow-left me-1"></i>Quay lại
                </a>
            </div>
        </div>
        <div class="card-body">
            <div class="alert alert-danger mb-4">
                <i class="fas fa-exclamation-triangle me-2"></i>
                <strong>Cảnh báo:</strong> Bạn có chắc chắn muốn xóa vi phạm này? Hành động này không thể hoàn tác.
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="mb-4">
                        <h5 class="text-muted mb-3">Thông tin vi phạm</h5>
                        <div class="card bg-light">
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="small text-muted">Mã vi phạm</label>
                                    <div class="h5">@Model.MaViPham</div>
                                </div>
                                <div class="mb-3">
                                    <label class="small text-muted">Ngày vi phạm</label>
                                    <div class="h5">@Model.NgayViPham.ToString("dd/MM/yyyy")</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="mb-4">
                        <h5 class="text-muted mb-3">Thông tin liên quan</h5>
                        <div class="card bg-light">
                            <div class="card-body">
                                <div class="mb-3">
                                    <label class="small text-muted">Sinh viên</label>
                                    <div class="h5">@Model.SinhVien?.HoTen</div>
                                </div>
                                <div class="mb-3">
                                    <label class="small text-muted">Nội quy vi phạm</label>
                                    <div class="h5">@Model.NoiQuy?.NoiDung</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <form asp-action="DeleteConfirmed" method="post" class="text-center mt-4">
                <input type="hidden" asp-for="MaViPham" />
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash me-1"></i>Xác nhận xóa
                </button>
                <a asp-action="Index" class="btn btn-secondary ms-2">
                    <i class="fas fa-times me-1"></i>Hủy
                </a>
            </form>
        </div>
    </div>
</div>
